<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.control.ScrollPane?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="org.example.examenjava.MessagingController"
            style="-fx-background-color: #f1f5f9;">

  <!-- TOP BAR -->
  <top>
    <HBox spacing="12" alignment="CENTER_LEFT"
          style="-fx-background-color: white; -fx-padding: 12 24; -fx-border-color: #e2e8f0; -fx-border-width: 0 0 1 0;">

      <!-- App Logo -->
      <StackPane>
        <Region style="-fx-background-color: linear-gradient(to bottom right, #6366f1, #8b5cf6); -fx-background-radius: 10; -fx-min-width: 36; -fx-min-height: 36; -fx-max-width: 36; -fx-max-height: 36;"/>
        <Label text="M" style="-fx-text-fill: white; -fx-font-size: 16; -fx-font-weight: bold;"/>
      </StackPane>

      <Label text="Messagerie" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>

      <Region HBox.hgrow="ALWAYS"/>

      <!-- Current User Info -->
      <VBox alignment="CENTER_RIGHT" spacing="1">
        <Label fx:id="currentUserLabel" text="Utilisateur" style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #334155;"/>
        <Label fx:id="onlineCountLabel" text="0 en ligne" style="-fx-font-size: 10; -fx-text-fill: #10b981;"/>
      </VBox>

      <!-- Members Button (ORGANISATEUR only) -->
      <Button fx:id="membersButton" text="Membres" onAction="#onShowMembersButtonClick"
              styleClass="btn-outline" visible="false" managed="false"/>

      <!-- Logout Button -->
      <Button fx:id="logoutButton" text="Deconnexion" onAction="#onLogoutButtonClick"
              styleClass="btn-danger-sm"/>
    </HBox>
  </top>

  <!-- MAIN CONTENT -->
  <center>
    <HBox spacing="0">

      <!-- LEFT SIDEBAR - CONTACTS -->
      <VBox styleClass="sidebar" minWidth="300" maxWidth="300">

        <!-- Search / Header -->
        <HBox alignment="CENTER_LEFT" style="-fx-padding: 16 20;">
          <Label text="Conversations" style="-fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
          <Region HBox.hgrow="ALWAYS"/>
        </HBox>

        <Separator style="-fx-padding: 0 16;"/>

        <!-- User List -->
        <ListView fx:id="userListView" styleClass="contact-list" VBox.vgrow="ALWAYS"/>

      </VBox>

      <!-- RIGHT SIDE - CHAT AREA -->
      <VBox spacing="0" HBox.hgrow="ALWAYS" style="-fx-background-color: #f8fafc;">

        <!-- Chat Header -->
        <HBox spacing="12" alignment="CENTER_LEFT"
              style="-fx-background-color: white; -fx-padding: 14 24; -fx-border-color: #e2e8f0; -fx-border-width: 0 0 1 0;">

          <VBox spacing="2">
            <Label fx:id="selectedUserLabel" text="Selectionnez un contact"
                   style="-fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
            <Label fx:id="userStatusLabel" text="Hors ligne" style="-fx-font-size: 11; -fx-text-fill: #94a3b8;"/>
          </VBox>

          <Region HBox.hgrow="ALWAYS"/>
        </HBox>

        <!-- Chat Messages Area -->
        <ScrollPane fx:id="chatScrollPane" fitToWidth="true" styleClass="chat-scroll" VBox.vgrow="ALWAYS">
          <content>
            <VBox fx:id="messagesContainer" spacing="6" style="-fx-padding: 16; -fx-background-color: transparent;"/>
          </content>
        </ScrollPane>

        <!-- Message Input Area -->
        <HBox spacing="10" alignment="CENTER"
              style="-fx-background-color: white; -fx-padding: 14 24; -fx-border-color: #e2e8f0; -fx-border-width: 1 0 0 0;">
          <TextField fx:id="messageField"
                     promptText="Ecrivez votre message..."
                     styleClass="message-input"
                     HBox.hgrow="ALWAYS"/>
          <Button fx:id="sendButton" text="Envoyer" onAction="#onSendButtonClick"
                  styleClass="btn-send"/>
        </HBox>

      </VBox>

    </HBox>
  </center>

</BorderPane>
