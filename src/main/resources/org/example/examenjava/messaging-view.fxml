<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.control.ScrollPane?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="org.example.examenjava.MessagingController"
            style="-fx-background-color: #f5f7fa;">

  <!-- TOP BAR -->
  <top>
    <HBox spacing="15" style="-fx-background-color: #2c3e50; -fx-padding: 15 20;" alignment="CENTER_LEFT">
      <Label text="💬 Messagerie Interne" style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: white;"/>
      <Region HBox.hgrow="ALWAYS"/>
      <Label fx:id="currentUserLabel" style="-fx-font-size: 13; -fx-text-fill: #ecf0f1;"/>
      <Separator orientation="VERTICAL" style="-fx-padding: 0 10;"/>
      <Button fx:id="logoutButton" text="🚪 Déconnexion" onAction="#onLogoutButtonClick"
              style="-fx-padding: 8 18; -fx-font-size: 12; -fx-background-color: #e74c3c; -fx-text-fill: white; -fx-border-radius: 5; -fx-background-radius: 5;"/>
    </HBox>
  </top>

  <!-- MAIN CONTENT -->
  <center>
    <HBox spacing="0" style="-fx-background-color: white;">

      <!-- LEFT SIDEBAR - CONTACTS -->
      <VBox style="-fx-background-color: #ecf0f1; -fx-border-color: #bdc3c7; -fx-border-width: 0 1 0 0;" minWidth="280" maxWidth="280">
        <padding>
          <Insets top="20" bottom="20" left="0" right="0"/>
        </padding>

        <!-- Contacts Header -->
        <HBox spacing="10" style="-fx-padding: 0 15;">
          <Label text="📋 Contacts" style="-fx-text-fill: #2c3e50; -fx-font-size: 16; -fx-font-weight: bold;"/>
          <Region HBox.hgrow="ALWAYS"/>
        </HBox>

        <Separator style="-fx-padding: 10 15;"/>

        <!-- User List -->
        <ListView fx:id="userListView"
                  style="-fx-control-inner-background: #ecf0f1; -fx-text-fill: #2c3e50; -fx-font-size: 13; -fx-padding: 5; -fx-border-color: transparent;"
                  VBox.vgrow="ALWAYS"/>

        <Region VBox.vgrow="ALWAYS"/>

        <!-- Status Info -->
        <VBox spacing="8" style="-fx-padding: 15; -fx-border-color: #bdc3c7; -fx-border-width: 1 0 0 0;">
          <Label text="Statut: En ligne" style="-fx-font-size: 11; -fx-text-fill: #27ae60;"/>
          <Label text="Dernière synchro: À l'instant" style="-fx-font-size: 10; -fx-text-fill: #7f8c8d;"/>
        </VBox>
      </VBox>

      <!-- RIGHT SIDE - CHAT AREA -->
      <VBox spacing="10" style="-fx-background-color: white;" HBox.hgrow="ALWAYS">
        <padding>
          <Insets top="20" bottom="20" left="20" right="20"/>
        </padding>

        <!-- Selected User Info -->
        <HBox spacing="15" alignment="CENTER_LEFT">
          <Label fx:id="selectedUserLabel" text="👤 Sélectionnez un contact"
                  style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
          <Region HBox.hgrow="ALWAYS"/>
          <Label fx:id="userStatusLabel" text="● Hors ligne" style="-fx-font-size: 11; -fx-text-fill: #7f8c8d;"/>
        </HBox>

        <Separator style="-fx-padding: 10 0;"/>

        <!-- Chat Display Area - replaced TextArea with ScrollPane + VBox -->
        <ScrollPane fx:id="chatScrollPane" fitToWidth="true" style="-fx-background-color: #f8f9fa; -fx-border-radius: 8; -fx-padding: 10;" VBox.vgrow="ALWAYS">
          <content>
            <VBox fx:id="messagesContainer" spacing="8" style="-fx-padding: 10; -fx-background-color: transparent;"/>
          </content>
        </ScrollPane>

        <!-- Message Input Area -->
        <HBox spacing="12" alignment="BOTTOM_RIGHT" style="-fx-padding: 10 0;">
          <TextField fx:id="messageField"
                     promptText="Tapez votre message ici..."
                     style="-fx-padding: 12 15; -fx-font-size: 13; -fx-border-color: #bdc3c7; -fx-border-radius: 8; -fx-background-radius: 8; -fx-text-fill: #2c3e50;"
                     HBox.hgrow="ALWAYS"
                     onAction="#onSendButtonClick"/>
          <Button fx:id="sendButton" text="📤 Envoyer" onAction="#onSendButtonClick"
                  style="-fx-padding: 12 24; -fx-font-size: 13; -fx-font-weight: bold; -fx-background-color: #3498db; -fx-text-fill: white; -fx-border-radius: 8; -fx-background-radius: 8;"/>
          <Button fx:id="clearButton" text="🗑️ Effacer"
                  style="-fx-padding: 12 18; -fx-font-size: 12; -fx-background-color: #95a5a6; -fx-text-fill: white; -fx-border-radius: 8; -fx-background-radius: 8;"/>
        </HBox>

      </VBox>

    </HBox>
  </center>

</BorderPane>

