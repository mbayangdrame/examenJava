<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="15.0" style="-fx-background-color: linear-gradient(to bottom, #2c3e50, #34495e); -fx-padding: 20;" xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.examenjava.LoginController">

  <VBox alignment="CENTER" spacing="20.0" style="-fx-background-color: white; -fx-border-radius: 10; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 10, 0, 0, 5);" VBox.vgrow="NEVER">
    <padding>
      <Insets bottom="40.0" left="40.0" right="40.0" top="40.0"/>
    </padding>

    <!-- Title -->
    <Label text="Messagerie Interne" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #2c3e50;">
      <font>
        <Font name="Arial" size="28.0"/>
      </font>
    </Label>

    <Label text="Bienvenue" style="-fx-font-size: 14; -fx-text-fill: #7f8c8d;"/>

    <!-- Username Field -->
    <Label text="Nom d'utilisateur" style="-fx-font-size: 12; -fx-text-fill: #2c3e50;"/>
    <TextField fx:id="usernameField" promptText="Entrez votre nom d'utilisateur"
               style="-fx-padding: 10; -fx-border-color: #bdc3c7; -fx-border-radius: 5; -fx-font-size: 12;"/>

    <!-- Password Field -->
    <Label text="Mot de passe" style="-fx-font-size: 12; -fx-text-fill: #2c3e50;"/>
    <PasswordField fx:id="passwordField" promptText="Entrez votre mot de passe"
                   style="-fx-padding: 10; -fx-border-color: #bdc3c7; -fx-border-radius: 5; -fx-font-size: 12;"/>

    <!-- Error Label -->
    <Label fx:id="errorLabel" style="-fx-text-fill: #e74c3c; -fx-font-size: 11;"/>

    <!-- Login Button -->
    <Button fx:id="loginButton" text="Connexion" onAction="#onLoginButtonClick"
            style="-fx-padding: 12; -fx-font-size: 14; -fx-font-weight: bold; -fx-background-color: #3498db; -fx-text-fill: white; -fx-border-radius: 5; -fx-background-radius: 5; -fx-cursor: hand;">
    </Button>

    <!-- Demo Credentials -->
    <Label text="Démo: admin / 123456" style="-fx-font-size: 10; -fx-text-fill: #95a5a6; -fx-font-style: italic;"/>

    <!-- Lien vers inscription -->
    <Button fx:id="registerLinkButton" text="Créer un compte" onAction="#onRegisterLinkClick"
            style="-fx-padding: 8; -fx-font-size: 12; -fx-background-color: #27ae60; -fx-text-fill: white; -fx-border-radius: 5; -fx-background-radius: 5; -fx-cursor: hand;"/>

  </VBox>

</VBox>

