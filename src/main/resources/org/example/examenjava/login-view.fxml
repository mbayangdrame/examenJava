<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>

<VBox alignment="CENTER" spacing="0"
      style="-fx-background-color: linear-gradient(to bottom right, #4f46e5, #7c3aed, #6366f1);"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.examenjava.LoginController">

  <!-- Main Card -->
  <VBox alignment="CENTER" spacing="0" maxWidth="400"
        style="-fx-background-color: white; -fx-background-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.25), 30, 0, 0, 10);">
    <padding>
      <Insets bottom="40" left="40" right="40" top="35"/>
    </padding>

    <!-- Logo / Icon -->
    <StackPane>
      <Region style="-fx-background-color: linear-gradient(to bottom right, #6366f1, #8b5cf6); -fx-background-radius: 30; -fx-min-width: 60; -fx-min-height: 60; -fx-max-width: 60; -fx-max-height: 60;"/>
      <Label text="M" style="-fx-text-fill: white; -fx-font-size: 26; -fx-font-weight: bold;"/>
    </StackPane>

    <Region style="-fx-min-height: 16;"/>

    <!-- Title -->
    <Label text="Messagerie Interne" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
    <Region style="-fx-min-height: 4;"/>
    <Label text="Connectez-vous pour acceder a vos messages" style="-fx-font-size: 12; -fx-text-fill: #94a3b8;"/>

    <Region style="-fx-min-height: 28;"/>

    <!-- Username Field -->
    <Label text="Nom d'utilisateur" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #475569;"/>
    <Region style="-fx-min-height: 6;"/>
    <TextField fx:id="usernameField" promptText="Entrez votre identifiant" styleClass="modern-field"/>

    <Region style="-fx-min-height: 16;"/>

    <!-- Password Field -->
    <Label text="Mot de passe" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #475569;"/>
    <Region style="-fx-min-height: 6;"/>
    <PasswordField fx:id="passwordField" promptText="Entrez votre mot de passe" styleClass="modern-field"/>

    <Region style="-fx-min-height: 10;"/>

    <!-- Error Label -->
    <Label fx:id="errorLabel" style="-fx-text-fill: #ef4444; -fx-font-size: 11;" wrapText="true"/>

    <Region style="-fx-min-height: 16;"/>

    <!-- Login Button -->
    <Button fx:id="loginButton" text="Se connecter" onAction="#onLoginButtonClick"
            styleClass="btn-primary" maxWidth="Infinity"/>

    <Region style="-fx-min-height: 12;"/>

    <!-- Separator -->
    <HBox alignment="CENTER" spacing="10">
      <Region style="-fx-background-color: #e2e8f0; -fx-min-height: 1; -fx-max-height: 1;" HBox.hgrow="ALWAYS"/>
      <Label text="ou" style="-fx-font-size: 11; -fx-text-fill: #94a3b8;"/>
      <Region style="-fx-background-color: #e2e8f0; -fx-min-height: 1; -fx-max-height: 1;" HBox.hgrow="ALWAYS"/>
    </HBox>

    <Region style="-fx-min-height: 12;"/>

    <!-- Register Link -->
    <Button fx:id="registerLinkButton" text="Creer un nouveau compte" onAction="#onRegisterLinkClick"
            styleClass="btn-secondary" maxWidth="Infinity"/>

  </VBox>

  <Region style="-fx-min-height: 20;"/>
  <Label text="Association Messagerie v1.0" style="-fx-text-fill: rgba(255,255,255,0.6); -fx-font-size: 11;"/>

</VBox>
