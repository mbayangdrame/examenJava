<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<VBox alignment="CENTER" spacing="15.0" style="-fx-background-color: linear-gradient(to bottom, #2c3e50, #34495e); -fx-padding: 20;" xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.examenjava.RegisterController">

  <VBox alignment="CENTER" spacing="20.0" style="-fx-background-color: white; -fx-border-radius: 10; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 10, 0, 0, 5);" VBox.vgrow="NEVER">
    <padding>
      <Insets bottom="40.0" left="40.0" right="40.0" top="40.0"/>
    </padding>

    <!-- Title -->
    <Label text="Inscription" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #2c3e50;">
      <font>
        <Font name="Arial" size="28.0"/>
      </font>
    </Label>
    <Label text="Créer un compte utilisateur" style="-fx-font-size: 14; -fx-text-fill: #7f8c8d;"/>

    <!-- Inputs group 1: Username + Email -->
    <HBox spacing="10">
      <VBox>
        <Label text="Nom d'utilisateur" style="-fx-font-size: 12; -fx-text-fill: #2c3e50;"/>
        <TextField fx:id="usernameField" promptText="Nom d'utilisateur"
                   style="-fx-padding: 10; -fx-border-color: #bdc3c7; -fx-border-radius: 5; -fx-font-size: 12;"/>
      </VBox>
      <VBox>
        <Label text="Email" style="-fx-font-size: 12; -fx-text-fill: #2c3e50;"/>
        <TextField fx:id="emailField" promptText="Email"
                   style="-fx-padding: 10; -fx-border-color: #bdc3c7; -fx-border-radius: 5; -fx-font-size: 12;"/>
      </VBox>
    </HBox>

    <!-- Inputs group 2: Password + Full Name -->
    <HBox spacing="10">
      <VBox>
        <Label text="Mot de passe" style="-fx-font-size: 12; -fx-text-fill: #2c3e50;"/>
        <PasswordField fx:id="passwordField" promptText="Mot de passe"
                       style="-fx-padding: 10; -fx-border-color: #bdc3c7; -fx-border-radius: 5; -fx-font-size: 12;"/>
      </VBox>
      <VBox>
        <Label text="Nom complet" style="-fx-font-size: 12; -fx-text-fill: #2c3e50;"/>
        <TextField fx:id="fullNameField" promptText="Nom complet"
                   style="-fx-padding: 10; -fx-border-color: #bdc3c7; -fx-border-radius: 5; -fx-font-size: 12;"/>
      </VBox>
    </HBox>

    <!-- Inputs group 3: Role + Retour Login -->
    <HBox spacing="10">
      <VBox>
        <Label text="Rôle" style="-fx-font-size: 12; -fx-text-fill: #2c3e50;"/>
        <ComboBox fx:id="roleComboBox" promptText="Choisissez un rôle"
                  style="-fx-padding: 10; -fx-border-color: #bdc3c7; -fx-border-radius: 5; -fx-font-size: 12;">
          <items>
            <FXCollections fx:factory="observableArrayList">
              <String fx:value="ORGANISATEUR"/>
              <String fx:value="MEMBRE"/>
              <String fx:value="BENEVOLE"/>
            </FXCollections>
          </items>
        </ComboBox>
      </VBox>
    </HBox>

    <!-- Error Label -->
    <Label fx:id="errorLabel" style="-fx-text-fill: #e74c3c; -fx-font-size: 11;"/>

    <!-- Register & Retour Login Buttons on same line -->
    <HBox spacing="10" alignment="CENTER">
      <Button fx:id="registerButton" text="S'inscrire" onAction="#onRegisterButtonClick"
              style="-fx-padding: 12; -fx-font-size: 14; -fx-font-weight: bold; -fx-background-color: #27ae60; -fx-text-fill: white; -fx-border-radius: 5; -fx-background-radius: 5; -fx-cursor: hand;"/>
      <Button fx:id="backToLoginButton" text="Retour à la connexion" onAction="#onBackToLoginClick"
              style="-fx-padding: 8; -fx-font-size: 12; -fx-background-color: #3498db; -fx-text-fill: white; -fx-border-radius: 5; -fx-background-radius: 5; -fx-cursor: hand;"/>
    </HBox>


  </VBox>

</VBox>
