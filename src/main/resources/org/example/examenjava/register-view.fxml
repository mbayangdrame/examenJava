<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<VBox alignment="CENTER" spacing="0"
      style="-fx-background-color: linear-gradient(to bottom right, #00a884, #008069, #005c4b);"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.examenjava.RegisterController">

  <!-- Main Card -->
  <VBox alignment="CENTER" spacing="0" maxWidth="480"
        style="-fx-background-color: #111b21; -fx-background-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.4), 30, 0, 0, 10);">
    <padding>
      <Insets bottom="35" left="40" right="40" top="30"/>
    </padding>

    <!-- Logo -->
    <StackPane>
      <Region style="-fx-background-color: #00a884; -fx-background-radius: 30; -fx-min-width: 60; -fx-min-height: 60; -fx-max-width: 60; -fx-max-height: 60;"/>
      <Label text="+" style="-fx-text-fill: white; -fx-font-size: 28; -fx-font-weight: bold;"/>
    </StackPane>

    <Region style="-fx-min-height: 12;"/>

    <Label text="Creer un compte" style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #e9edef;"/>
    <Region style="-fx-min-height: 3;"/>
    <Label text="Votre compte sera active par un organisateur" style="-fx-font-size: 12; -fx-text-fill: #8696a0;"/>

    <Region style="-fx-min-height: 24;"/>

    <!-- Row 1: Username + Email -->
    <HBox spacing="12">
      <VBox HBox.hgrow="ALWAYS">
        <Label text="Nom d'utilisateur" style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #8696a0;"/>
        <Region style="-fx-min-height: 4;"/>
        <TextField fx:id="usernameField" promptText="Identifiant" styleClass="modern-field"/>
      </VBox>
      <VBox HBox.hgrow="ALWAYS">
        <Label text="Email" style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #8696a0;"/>
        <Region style="-fx-min-height: 4;"/>
        <TextField fx:id="emailField" promptText="votre@email.com" styleClass="modern-field"/>
      </VBox>
    </HBox>

    <Region style="-fx-min-height: 14;"/>

    <!-- Row 2: Password + Full Name -->
    <HBox spacing="12">
      <VBox HBox.hgrow="ALWAYS">
        <Label text="Mot de passe" style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #8696a0;"/>
        <Region style="-fx-min-height: 4;"/>
        <PasswordField fx:id="passwordField" promptText="Mot de passe" styleClass="modern-field"/>
      </VBox>
      <VBox HBox.hgrow="ALWAYS">
        <Label text="Nom complet" style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #8696a0;"/>
        <Region style="-fx-min-height: 4;"/>
        <TextField fx:id="fullNameField" promptText="Prenom Nom" styleClass="modern-field"/>
      </VBox>
    </HBox>

    <Region style="-fx-min-height: 14;"/>

    <!-- Row 3: Role -->
    <Label text="Role dans l'association" style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #8696a0;"/>
    <Region style="-fx-min-height: 4;"/>
    <ComboBox fx:id="roleComboBox" promptText="Selectionnez votre role" styleClass="modern-combo" maxWidth="Infinity">
      <items>
        <FXCollections fx:factory="observableArrayList">
          <String fx:value="MEMBRE"/>
          <String fx:value="BENEVOLE"/>
        </FXCollections>
      </items>
    </ComboBox>

    <Region style="-fx-min-height: 10;"/>

    <!-- Error Label -->
    <Label fx:id="errorLabel" style="-fx-font-size: 11;" wrapText="true"/>

    <Region style="-fx-min-height: 18;"/>

    <!-- Buttons -->
    <Button fx:id="registerButton" text="S'inscrire" onAction="#onRegisterButtonClick"
            styleClass="btn-success" maxWidth="Infinity"/>

    <Region style="-fx-min-height: 10;"/>

    <Button fx:id="backToLoginButton" text="Retour a la connexion" onAction="#onBackToLoginClick"
            styleClass="btn-ghost" maxWidth="Infinity"/>

  </VBox>

  <Region style="-fx-min-height: 20;"/>
  <Label text="Élan v1.0" style="-fx-text-fill: rgba(255,255,255,0.6); -fx-font-size: 11;"/>

</VBox>
